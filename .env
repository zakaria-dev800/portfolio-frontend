VITE_EMAIL_ENDPOINT=https://example.com/.netlify/functions/send-email
# Replace the value above with your serverless function or API endpoint that accepts POST JSON payloads:
# { name, email, subject, message, phone, hcaptcha }
# Examples:
# - Netlify Functions: https://<your-site>.netlify.app/.netlify/functions/send-email
# - Vercel Serverless: https://<your-deployment>/api/send-email
# - Form handling services: https://formspree.io/f/<your-id> (may require different payload)